# Copy this file to .env.local and fill in your values
# Get these from your Supabase project dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App config
VITE_APP_NAME=Orbit
VITE_APP_VERSION=0.1.0

# Monitoring endpoint (optional)
# MUST be a URL whose origin is permitted by connect-src in vercel.json.
# The safest option is a Supabase Edge Function — *.supabase.co is already
# in the CSP allowlist. Any other host requires a matching entry in connect-src.
# Example: https://your-project.supabase.co/functions/v1/ingest-monitoring-event
VITE_MONITORING_ENDPOINT=
